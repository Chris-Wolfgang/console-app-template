{
	"$schema": "http://json.schemastore.org/template",
	"author": "Chris Wolfgang",
	"classifications": [ "C#", "Code" ],
	"identity": "Wolfgang.Preconfigured.Console.SubCommand",
	"name": "Wolfgang Preconfigured Console App SubCommand",
	"shortName": "cwsubcmd",
	"sourceName": "SubCommandTemplate",
	"description": "A preconfigured SubCommand for use with Wolfgang Preconfigured Console App SubCommand",
	"defaultName": "SubCommand",
	"macros": [
		{
			"type": "evaluate",
			"name": "currentYear",
			"value": "now:yyyy"
		}
	],


	"tags": {
		"language": "C#",
        	"type": "item"
	},

	"symbols": {
		"DefaultNamespace": {
			"type": "bind",
			"binding": "msbuild:RootNamespace",
			"replaces": "MyNamespace",
			"defaultValue": "Fallback.Namespace"
		},
	

		"response-file": {
			"type": "parameter",
			"description": "Response file support. Command line arguments can be added to a response file and the response can be passed in as though each argument was manually typed at the commandline",
			"datatype": "choice",
			"choices": [
				{
					"choice": "Disabled",
					"description": "Disabled",
					"displayName": "Disabled - No response file support.",
					"documentation": ""
				},
				{
					"choice": "ParseArgsAsLineSeparated",
					"description": "Line separated",
					"displayName": "Line separated - Each argument is on a new line.",
					"documentation": ""
				},
				{
					"choice": "ParseArgsAsSpaceSeparated",
					"description": "Space separated",
					"displayName": "Space separated - All arguments are on a single line in separated by spaces.",
					"documentation": ""
				}
			],
			"replaces": "ParseArgsAsSpaceSeparated",
			"defaultValue": "ParseArgsAsLineSeparated"
		}
	},
    "primaryOutputs": [
		{ "path": "%name%.cs" }
    ]
}
