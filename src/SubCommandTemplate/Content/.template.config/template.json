{
	"$schema": "http://json.schemastore.org/template",
	"author": "Chris Wolfgang",
	"classifications": [ "C#", "Code" ],
	"identity": "Wolfgang.Template.Console.SubCommand",
	"name": "Wolfgang Console SubCommand",
	"shortName": "cwsubcmd",
	"sourceName": "SubCommandTemplate",
	"description": "A preconfigured SubCommand for use with Wolfgang Console App Template",
	"defaultName": "SubCommand",
	"thirdPartyNotices": "https://github.com/Chris-Wolfgang/console-app-template/blob/main/THIRD-PARTY-NOTICES.md",
	"macros": [
	],

	"tags": {
		"language": "C#",
		"type": "item"
	},

	"forms": {
		"toResponseFileHandling": {
			"identifier": "replace",
			"pattern": "^(Line|Space)Separated$",
			"replacement": "ParseArgsAs$1Separated"
		}
	},

	"symbols": {
		"ClassName": {
			"type": "parameter",
			"description": "The name of the subcommand class",
			"datatype": "text",
			"replaces": "SubCommandTemplate",
			"fileRename": "SubCommandTemplate",
			"defaultValue": "SubCommand"
		},

		"DefaultNamespace": {
			"type": "bind",
			"binding": "msbuild:RootNamespace",
			"replaces": "{DefaultNamespace}"
		},

		"alternative-name": {
			"type": "parameter",
			"datatype": "string",
			"description": "An alternate name for the command. If not specified the command will use the default value based on the class name",
			"replaces": "{alternative-name}",
			"defaultValue": "<you can specify an alternative name>"
		},

		"description": {
			"type": "parameter",
			"datatype": "string",
			"description": "A description for the command",
			"replaces": "{command-description}",
			"defaultValue": "<provide a description>"
		},

		"response-file": {
			"type": "parameter",
			"description": "Response file support. A response file is a text file of command line arguments that users can pass as @file.rsp instead of typing each argument at the command line",
			"datatype": "choice",
			"choices": [
				{
					"choice": "Disabled",
					"displayName": "Disabled",
					"description": "No response file support"
				},
				{
					"choice": "LineSeparated",
					"displayName": "Line separated",
					"description": "Each argument in the response file is on its own line"
				},
				{
					"choice": "SpaceSeparated",
					"displayName": "Space separated",
					"description": "All arguments in the response file are on a single line, separated by spaces"
				}
			],
			"defaultValue": "LineSeparated"
		},

		"response-file-handling": {
			"type": "derived",
			"valueSource": "response-file",
			"valueTransform": "toResponseFileHandling",
			"replaces": "ParseArgsAsSpaceSeparated"
		}
	},
	"primaryOutputs": [
		{ "path": "%name%.cs" }
	]
}
 