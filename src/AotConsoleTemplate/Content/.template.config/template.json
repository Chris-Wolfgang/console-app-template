{
	"$schema": "http://json.schemastore.org/template",
	"author": "Chris Wolfgang",
	"classifications": [ "Console", "AOT" ],
	"identity": "Wolfgang.Template.Console.Aot",
	"name": "Wolfgang Console App (Native AOT)",
	"shortName": "cwconsole-aot",
	"sourceName": "AotConsoleTemplate",
	"description": "A native-AOT-ready console application using System.CommandLine, the generic host (DI + logging) and source-generated configuration binding.",
	"defaultName": "ConsoleApp",
	"thirdPartyNotices": "https://github.com/Chris-Wolfgang/console-app-template/blob/main/THIRD-PARTY-NOTICES.md",

	"baselines": {
		"default": {
			"defaultOverrides": {
				"framework": "net8.0",
				"version": "0.1.0"
			}
		}
	},

	"tags": {
		"language": "C#",
		"type": "project"
	},

	"symbols": {
		"framework": {
			"type": "parameter",
			"description": "The target framework for the project.",
			"datatype": "choice",
			"choices": [
				{
					"choice": "net8.0",
					"description": ".NET 8.0 (LTS)"
				},
				{
					"choice": "net9.0",
					"description": ".NET 9.0 (STS)"
				},
				{
					"choice": "net10.0",
					"description": ".NET 10.0 (LTS)"
				}
			],
			"replaces": "net8.0",
			"defaultValue": "net8.0"
		},

		"version": {
			"type": "parameter",
			"description": "Initial version number for the project.",
			"datatype": "text",
			"replaces": "0.1.0",
			"defaultValue": "0.1.0"
		},

		"author": {
			"type": "parameter",
			"description": "The name of the company or person that authored this project. This name will appear in the <Author> tag in the csproj and in the copyright",
			"datatype": "text",
			"replaces": "{author}",
			"defaultValue": "(your company)"
		},

		"description": {
			"type": "parameter",
			"description": "A description of this application. This name will appear in the <Description> tag in the csproj and in the copyright",
			"datatype": "text",
			"replaces": "{description}",
			"defaultValue": "(Console Application)"
		},

		"currentYear": {
			"type": "generated",
			"generator": "now",
			"parameters": {
				"format": "yyyy"
			},
			"replaces": "{copyright year}"
		}
	},

	"primaryOutputs": [
		{
			"path": "Instructions.md"
		}
	],

	"postActions": [
		{
			"description": "Open Instructions.md",
			"manualInstructions": [],
			"actionId": "84C0DA21-51C8-4541-9940-6CA19AF04EE6",
			"args": {
				"files": "0"
			},
			"continueOnError": true
		}
	]
}
